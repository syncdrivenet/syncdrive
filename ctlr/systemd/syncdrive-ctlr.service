[Unit]
Description=SyncDrive Controller
After=network.target mnt-storage.mount mnt-export.mount
Wants=mnt-storage.mount mnt-export.mount

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/syncdrive/ctlr
Environment=CTLR_CONFIG=/data/ctlr/config.yml
ExecStart=/usr/bin/python3 main.py
Restart=always
RestartSec=5

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=syncdrive-ctlr

[Install]
WantedBy=multi-user.target
