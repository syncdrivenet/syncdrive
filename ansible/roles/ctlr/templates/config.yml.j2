node:
  name: {{ inventory_hostname }}

cameras:
{% for host in groups['cameras'] %}
  - name: {{ host }}
    host: {{ hostvars[host]['ansible_host'] }}
    port: 8080
{% endfor %}

storage:
  recordings_dir: {{ ctlr_storage_path }}
  export_dir: {{ ctlr_export_path }}

recording:
  segment_duration: {{ recording.segment_duration }}

logging:
  dir: {{ ctlr_logs_path }}
  level: INFO

api:
  host: 0.0.0.0
  port: {{ controller_port }}
